# Copy this file to .env for local development.

# Recruiter/demo mode runs polished mock agent outputs without calling Groq.
# Set DEMO_MODE=false when you want live LLM responses.
DEMO_MODE=true

# Required only when DEMO_MODE=false.
GROQ_API_KEY=your_groq_api_key_here

# Flask backend port used by index.html.
PORT=5050

# Optional: maximum upload size in bytes. Default is 16 MB.
MAX_CONTENT_LENGTH=16777216

# Optional: directory where uploaded files are stored.
UPLOAD_DIR=data
