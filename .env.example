# Copy this file to .env for local development.

# Recruiter/demo mode runs polished mock agent outputs without calling an LLM provider.
# Set DEMO_MODE=false when you want live LLM responses.
DEMO_MODE=true

# Default live provider. Supported: groq, openai, anthropic, gemini, openrouter, ollama.
LLM_PROVIDER=groq

# Required only for the matching live provider. Do not commit real keys.
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Ollama local live mode. Start Ollama locally before using this provider.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Flask backend port used by index.html.
PORT=5050

# Optional: maximum upload size in bytes. Default is 16 MB.
MAX_CONTENT_LENGTH=16777216

# Optional: directory where uploaded files are stored.
UPLOAD_DIR=data
